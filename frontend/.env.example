# Copy to .env and fill from Terraform outputs (infra/envs/seoul).
VITE_REGION=ap-northeast-2
VITE_USER_POOL_ID=ap-northeast-2_xxxxxxxxx
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Full AgentCore Runtime ARN, e.g. arn:aws:bedrock-agentcore:ap-northeast-2:<acct>:runtime/fsi_mythos-xxxxxxxxxx
VITE_RUNTIME_ARN=
